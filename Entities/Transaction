{
  "name": "Transaction",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "deposit",
        "withdrawal",
        "bet_placed",
        "bet_won",
        "bet_refund",
        "bonus"
      ],
      "description": "Transaction type"
    },
    "amount": {
      "type": "number",
      "description": "Transaction amount"
    },
    "balance_after": {
      "type": "number"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "completed",
        "failed",
        "cancelled"
      ],
      "default": "completed"
    },
    "reference_id": {
      "type": "string",
      "description": "Related bet or payment ID"
    }
  },
  "required": [
    "user_email",
    "type",
    "amount"
  ]
}
